{
  "id": "com.ridsys.iqdisplayplayer",
  "version": "1.0.2",
  "vendor": "MRRIDSYS TECHNOLOGIES PRIVATE LIMITED",
  "type": "web",
  "main": "www/index.html",
  "title": "IQ WebOS Player",
  "icon": "icon.png",
  "largeIcon": "icon.png",
  "requiredVersion": "7.0",
  "resolution": "1920x1080",
  "supportedModels": [
    "webOS23",
    "webOS24",
    "webOS25"
  ],

  "bgColor": "black",
  "uiRevision": 2,
  "supportFullscreen": true,
  "fullscreen": true,
  "visible": true,
  "noWindow": false,
  "disableBackHistoryAPI": true,

  "requiredPermissions": [
    "accesswebosservice",
    "public",
    "webos.permission.applicationManager",
    "webos.permission.INTERNET"
  ],

  "permissions": [
    "systeminfo",
    "network.query",
    "network.management",
    "network"
  ],

  "keyFilter": {
    "back": "true"
  }
}